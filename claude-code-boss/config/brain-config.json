{
  "version": 2,
  "description": "Brain Research — pluggable backend (local SQLite or MCP Memory Server) + embedding provider.",
  "backend": {
    "type": "local",
    "mcpMemory": {
      "jarPath": "",
      "javaArgs": ["-Xmx512m"],
      "downloadUrl": "https://github.com/AllanSantos-DV/mcp-memory-server-releases/releases/download/v2.6.0/mcp-memory-server-2.6.0.jar",
      "expectedSha256": "",
      "timeout": 60000
    }
  },
  "embedder": {
    "provider": "transformers",
    "model": "Xenova/paraphrase-multilingual-MiniLM-L12-v2",
    "dimensions": 384
  },
  "kb": {
    "projectScope": true,
    "maxEntriesPerProject": 10000,
    "archiveAfterDays": 90,
    "retrieval": {
      "fastTopK": 5,
      "deepTopK": 3,
      "minScoreFast": 0.05,
      "minScoreDeep": 0.08
    },
    "rerank": {
      "enabled": true,
      "halfLifeDays": 30,
      "weights": { "relevance": 0.5, "recency": 0.2, "frequency": 0.15, "confidence": 0.15 }
    },
    "submission": {
      "minBashLines": 3,
      "minOutputChars": 1500
    },
    "skillPromotion": {
      "enabled": true,
      "minRecurrence": 3,
      "minConfidence": 0.8,
      "types": ["lesson", "pattern"]
    }
  },
  "curation": {
    "maxOutputChars": 1500,
    "maxOutputLines": 30
  }
}
