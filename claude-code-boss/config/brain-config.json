{
  "version": 2,
  "description": "Brain Research — pluggable backend (local SQLite or MCP Memory Server) + embedding provider.",
  "backend": {
    "type": "local",
    "mcpMemory": {
      "jarPath": "",
      "javaArgs": ["-Xmx512m"],
      "downloadUrl": "https://github.com/AllanSantos-DV/mcp-memory-server-releases/releases/download/v2.6.0/mcp-memory-server-2.6.0.jar",
      "timeout": 60000
    }
  },
  "embedder": {
    "provider": "transformers",
    "model": "Xenova/all-MiniLM-L6-v2",
    "dimensions": 384
  },
  "kb": {
    "projectScope": true,
    "maxEntriesPerProject": 10000,
    "archiveAfterDays": 90,
    "hybridSearch": true,
    "vectorWeight": 0.7,
    "keywordWeight": 0.2,
    "metadataWeight": 0.1,
    "retrieval": {
      "fastTopK": 5,
      "deepTopK": 3,
      "minScoreFast": 0.3,
      "minScoreDeep": 0.5
    },
    "submission": {
      "minBashLines": 3,
      "minOutputChars": 500,
      "dedupThreshold": 0.95
    }
  },
  "curation": {
    "maxOutputChars": 1500,
    "maxOutputLines": 30
  }
}
