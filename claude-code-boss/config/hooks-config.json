{
  "profile": "standard",
  "memoryRotate": {
    "maxLines": 150
  },
  "curation": {
    "scriptsDir": ".vscode/scripts",
    "shellsConfigPath": ".vscode/shells.json",
    "scriptsDirSearch": [".vscode/scripts", ".curation/scripts", "scripts"],
    "shellsConfigSearch": [".vscode/shells.json", ".curation/shells.json", "shells.json"]
  },
  "curationGuard": {
    "denyUnknown": false
  },
  "errorGuard": {
    "enabled": true,
    "threshold": 2,
    "windowDays": 90
  },
  "policyInject": {
    "enabled": true,
    "maxPolicies": 10,
    "maxChars": 4000
  },
  "captureTriggerEvidence": {
    "enabled": false,
    "ttlDays": 7,
    "maxPerProject": 500,
    "maxSnippetChars": 2000
  },
  "projectSnapshot": {
    "enabled": true,
    "includeGh": "auto",
    "dirtyAgeThresholdHours": 24,
    "maxItemsPerSection": 5,
    "cacheTtlSeconds": 300
  },
  "failureRetro": {
    "minFailures": 2,
    "timeWindowMin": 10,
    "consecutiveThreshold": 3
  },
  "activeResearch": {
    "enabled": true,
    "triggers": {
      "libMention": true,
      "versionMention": true,
      "bestPracticeAsk": true,
      "integrationMention": true
    },
    "maxPerSession": 3,
    "cooldownMinutes": 60,
    "depth": "quick",
    "fireThreshold": 1.0
  },
  "autoContinue": {
    "maxBlocks": 1
  },
  "verifyNudge": {
    "maxBlocks": 1,
    "testPatterns": []
  },
  "selfReview": {
    "topK": 2,
    "minScore": 0.2,
    "types": ["lesson", "failure"]
  }
}
