{
  "version": 2,
  "description": "Model routing config with billing awareness. Tiers define cost buckets; costSensitive agents auto-downgrade when possible.",
  "defaultModel": "inherit",
  "costSensitive": true,
  "alertThreshold": 20,
  "tiers": {
    "inherit": { "rank": 0, "multiplier": 0, "label": "free", "description": "Modelo default do Claude Code (sem custo adicional)" },
    "haiku": { "rank": 1, "multiplier": 1, "label": "cheap", "description": "Barato, ideal para análises rápidas e roteamento simples" },
    "sonnet": { "rank": 2, "multiplier": 3, "label": "standard", "description": "Equilíbrio custo-qualidade para a maioria das tarefas" },
    "opus": { "rank": 3, "multiplier": 7, "label": "premium", "description": "Caro, reservado para tarefas complexas com LLM crítico" }
  },
  "agents": {
    "octopus": { "model": "inherit", "minTier": "standard", "costSensitive": true, "label": "Router principal" },
    "implementor": { "model": "inherit", "minTier": "standard", "costSensitive": true, "label": "Implementação de código" },
    "researcher": { "model": "inherit", "minTier": "cheap", "costSensitive": true, "label": "Pesquisa exploratória" },
    "planner": { "model": "inherit", "minTier": "standard", "costSensitive": true, "label": "Planejamento arquitetural" },
    "reviewer": { "model": "inherit", "minTier": "standard", "costSensitive": true, "label": "Revisão de código" },
    "validator": { "model": "inherit", "minTier": "standard", "costSensitive": true, "label": "Validação (compile/lint/test)" },
    "debugger": { "model": "inherit", "minTier": "standard", "costSensitive": true, "label": "Diagnóstico de bugs" },
    "documenter": { "model": "inherit", "minTier": "cheap", "costSensitive": true, "label": "Documentação" },
    "brain-consolidator": { "model": "inherit", "minTier": "standard", "costSensitive": true, "label": "Síntese de pesquisa" },
    "brain-source-researcher": { "model": "inherit", "minTier": "cheap", "costSensitive": true, "label": "Pesquisa de fonte única" },
    "pattern-analyzer": { "model": "haiku", "minTier": "cheap", "costSensitive": false, "label": "Análise de padrões (sempre barato)" },
    "correction-analyzer": { "model": "haiku", "minTier": "cheap", "costSensitive": false, "label": "Análise de correções (sempre barato)" },
    "curation-improver": { "model": "sonnet", "minTier": "standard", "costSensitive": false, "label": "Melhoria de curadoria (qualidade > custo)" },
    "refine-researcher": { "model": "sonnet", "minTier": "standard", "costSensitive": true, "label": "Pesquisa refine (pode usar haiku se simples)" }
  }
}
